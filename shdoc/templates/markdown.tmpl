{{- /*
================================================================================
SHDOC-NG DEFAULT MARKDOWN TEMPLATE
================================================================================

DATA MODEL
----------
This template receives a Document at the top level. When rendering each
function, funcBlock receives a FuncDoc value.

Document fields (top-level):
  .FileTitle       string     — @name value
  .FileBrief       string     — brief description on @name line
  .FileDescription string     — @description block at file level
  .Authors         []string   — @author values
  .License         string     — @license value
  .Version         string     — @version value
  .Sections        []Section

Section fields:
  .Name        string     — @section heading (## level), may be empty
  .Description string     — text block after @section, may be empty
  .Functions   []FuncDoc

FuncDoc fields (passed to funcBlock and all sec* templates):
  .Name        string        — function name
  .IsDeprecated     bool          — true when @deprecated is present
  .DeprecatedMessage string       — @deprecated message, may be empty
  .Description string        — @description block
  .Warnings    []string      — @warning values
  .Example     string        — @example block (raw, use unindent to strip indent)
  .Options     []OptionEntry — @option entries that passed validation
  .BadOptions  []string      — @option entries that failed validation (raw text)
  .Args        []ArgEntry    — @arg entries
  .IsNoArgs    bool          — true when @noargs is present
  .Sets        []VarEntry    — @set entries
  .Env         []VarEntry    — @env entries
  .ExitCodes   []ExitEntry   — @exitcode entries
  .Stdin       []string      — @stdin values
  .Stdout      []string      — @stdout values
  .Stderr      []string      — @stderr values
  .Labels      []string      — @label values
  .See         []SeeRef      — @see values

OptionEntry:  .Forms []OptionForm, .Definition string
OptionForm:   .Name string (e.g. "-v"), .Value string, .ValueSep string ("" | " " | "=")
ArgEntry:     .Name string, .Type string, .Description string
VarEntry:     .Name string, .Type string, .Description string
ExitEntry:    .Code string, .Description string
SeeRef:       .Kind string ("ref"|"url"|"path"|"link"|"text"), .Text string, .Href string

TEMPLATE FUNCTIONS
------------------
  slug text            — GitHub-compatible anchor (lowercase, spaces→dashes)
  unindent text        — strip common leading whitespace from a block
  trimSpace text       — trim leading/trailing whitespace
  replaceAll s old new — replace all occurrences of old with new in s
  mdEscape text        — escape < and > for markdown (\< \>)
  mdBold text          — wrap in **...**
  mdLink text href     — produce [text](href)
  mdAnchor text        — produce [text](#slug)
  mdLinkify text       — wrap bare URLs in markdown links, leave existing links
  optionFormStr form   — reconstruct display string for an OptionForm
  renderSeeRef ref     — render a SeeRef to a markdown link or text (convenience; see secSee for manual approach)

SECTION TEMPLATE CONTRACT
-------------------------
Every sec* template produces either:
  - empty string   — when the corresponding field is absent/empty
  - "\n\ncontent"  — when the field has content (blank-line separator included)
Content never ends with a trailing newline; funcBlock appends a final "\n".
================================================================================
*/ -}}

{{- /* secDeprecated — @deprecated notice */ -}}
{{- define "secDeprecated" -}}
{{- if .IsDeprecated -}}
{{if eq .DeprecatedMessage ""}}{{"\n\n**DEPRECATED.**"}}{{else}}{{"\n\n**DEPRECATED:** "}}{{replaceAll .DeprecatedMessage "\n" "\n"}}{{end}}{{- end -}}
{{- end -}}

{{- /* secDescription — @description block */ -}}
{{- define "secDescription" -}}
{{- if .Description}}{{"\n\n"}}{{.Description}}{{- end -}}
{{- end -}}

{{- /* secWarnings — @warning list */ -}}
{{- define "secWarnings" -}}
{{- if .Warnings}}{{"\n\n#### Warnings\n\n"}}{{range $i, $w := .Warnings}}{{if $i}}{{"\n"}}{{end}}* {{replaceAll $w "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secExample — @example fenced code block */ -}}
{{- define "secExample" -}}
{{- if .Example}}{{"\n\n#### Example\n\n```bash\n"}}{{unindent .Example}}{{"\n```"}}{{- end -}}
{{- end -}}

{{- /*
secOptions — @option list (valid entries) and bad-option fallback lines.

Each valid option entry renders as:
  * **-f** | **--flag**
                          ← blank line between term and definition
    Definition text.
                          ← blank line between consecutive options
Bad options (entries that failed format validation) follow with no blank lines.
*/ -}}
{{- define "secOptions" -}}
{{- if or .Options .BadOptions}}{{"\n\n#### Options\n\n"}}{{range $i, $o := .Options}}{{if $i}}{{"\n\n"}}{{end}}* {{range $j, $f := $o.Forms}}{{if $j}} | {{end}}{{mdBold (mdEscape (optionFormStr $f))}}{{end}}{{"\n\n  "}}{{replaceAll $o.Definition "\n" "\n  "}}{{end}}{{if and .Options .BadOptions}}{{"\n\n"}}{{end}}{{range $i, $b := .BadOptions}}{{if $i}}{{"\n"}}{{end}}* {{$b}}{{end}}{{- end -}}
{{- end -}}

{{- /* secArgs — @arg list; $@ renders as **...** */ -}}
{{- define "secArgs" -}}
{{- if .Args}}{{"\n\n#### Arguments\n\n"}}{{range $i, $a := .Args}}{{if $i}}{{"\n"}}{{end}}{{if eq $a.Name "$@"}}* **...** ({{$a.Type}}): {{replaceAll $a.Description "\n" "\n  "}}{{else}}* **{{$a.Name}}** ({{$a.Type}}): {{replaceAll $a.Description "\n" "\n  "}}{{end}}{{end}}{{- end -}}
{{- end -}}

{{- /* secNoArgs — @noargs marker */ -}}
{{- define "secNoArgs" -}}
{{- if .IsNoArgs}}{{"\n\n_Function has no arguments._"}}{{- end -}}
{{- end -}}

{{- /* secSets — @set list */ -}}
{{- define "secSets" -}}
{{- if .Sets}}{{"\n\n#### Variables set\n\n"}}{{range $i, $s := .Sets}}{{if $i}}{{"\n"}}{{end}}* **{{$s.Name}}** ({{$s.Type}}): {{replaceAll $s.Description "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secEnv — @env list */ -}}
{{- define "secEnv" -}}
{{- if .Env}}{{"\n\n#### Environment variables\n\n"}}{{range $i, $e := .Env}}{{if $i}}{{"\n"}}{{end}}* **{{$e.Name}}** ({{$e.Type}}): {{replaceAll $e.Description "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secExitCodes — @exitcode list */ -}}
{{- define "secExitCodes" -}}
{{- if .ExitCodes}}{{"\n\n#### Exit codes\n\n"}}{{range $i, $e := .ExitCodes}}{{if $i}}{{"\n"}}{{end}}* **{{$e.Code}}**: {{replaceAll $e.Description "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secStdin — @stdin list; multi-line items get continuation lines indented */ -}}
{{- define "secStdin" -}}
{{- if .Stdin}}{{"\n\n#### Input on stdin\n\n"}}{{range $i, $s := .Stdin}}{{if $i}}{{"\n"}}{{end}}* {{replaceAll $s "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secStdout — @stdout list */ -}}
{{- define "secStdout" -}}
{{- if .Stdout}}{{"\n\n#### Output on stdout\n\n"}}{{range $i, $s := .Stdout}}{{if $i}}{{"\n"}}{{end}}* {{replaceAll $s "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secStderr — @stderr list */ -}}
{{- define "secStderr" -}}
{{- if .Stderr}}{{"\n\n#### Output on stderr\n\n"}}{{range $i, $s := .Stderr}}{{if $i}}{{"\n"}}{{end}}* {{replaceAll $s "\n" "\n  "}}{{end}}{{- end -}}
{{- end -}}

{{- /* secLabels — @label list; renders as code spans joined by · */ -}}
{{- define "secLabels" -}}
{{- if .Labels}}{{"\n\n#### Labels\n\n"}}{{range $i, $l := .Labels}}{{if $i}} · {{end}}`{{$l}}`{{end}}{{- end -}}
{{- end -}}

{{- /* secSee — @see list; renders each SeeRef using its Kind/Text/Href fields */ -}}
{{- define "secSee" -}}
{{- if .See}}{{"\n\n#### See also\n\n"}}{{range $i, $s := .See}}{{if $i}}{{"\n"}}{{end}}* {{if eq $s.Kind "path"}}{{mdLink $s.Href $s.Href}}{{else if eq $s.Kind "url"}}{{mdLink $s.Href $s.Href}}{{else if eq $s.Kind "link"}}{{mdLink $s.Text $s.Href}}{{else if eq $s.Kind "ref"}}{{mdAnchor $s.Text}}{{else}}{{mdLinkify $s.Text}}{{end}}{{end}}{{- end -}}
{{- end -}}

{{- /*
funcBlock renders a complete function documentation block.
The "### FuncName" heading, followed by all sections.
Each sec* call adds "\n\ncontent" or nothing; the final {{"\n"}} closes the block.
*/ -}}
{{- define "funcBlock" -}}
### {{.Name}}
{{- template "secDeprecated"  .}}
{{- template "secDescription" .}}
{{- template "secWarnings"    .}}
{{- template "secExample"     .}}
{{- template "secOptions"     .}}
{{- template "secArgs"        .}}
{{- template "secNoArgs"      .}}
{{- template "secSets"        .}}
{{- template "secEnv"         .}}
{{- template "secExitCodes"   .}}
{{- template "secStdin"       .}}
{{- template "secStdout"      .}}
{{- template "secStderr"      .}}
{{- template "secLabels"      .}}
{{- template "secSee"         .}}
{{- "\n"}}
{{- end -}}

{{- /* ── Document body ──────────────────────────────────────────────────── */}}

{{- /* File-level header: title, brief, description, authors, license, version */}}
{{- if .FileTitle}}# {{.FileTitle}}

{{if .FileBrief}}{{.FileBrief}}

{{end -}}
{{- if .FileDescription}}## Overview

{{.FileDescription}}

{{end -}}
{{- if .Authors}}#### Authors

{{range .Authors}}* {{.}}
{{end}}
{{end -}}
{{- if .License}}#### License

{{.License}}

{{end -}}
{{- if .Version}}#### Version

{{.Version}}

{{end -}}
{{- end -}}

{{- /* Table of contents */}}
{{- if .Sections}}## Index

{{range .Sections}}{{range .Functions}}* {{mdAnchor .Name}}
{{end}}{{end}}
{{end -}}

{{- /*
Section and function blocks.

Outer loop: iterate sections ($si = section index, $sec = section).
  - Named sections emit a ## heading with optional description.
  - Unnamed sections (functions before any @section) emit no heading.

Inner loop: iterate functions within each section ($fi = function index).

Blank-line logic:
  - Between consecutive functions: $fi > 0 always inserts a separator.
  - Before the section heading: $si > 0 inserts a separator (skip for the
    very first section to avoid a leading blank line).
  - First function in a named section: NO separator — the heading already
    ends with \n\n.
  - First function in an unnamed section after section 0: separator needed
    because there's no heading to provide spacing.
*/ -}}
{{- range $si, $sec := .Sections -}}
{{- /* Section heading (only for named sections, with separator before non-first ones) */ -}}
{{- if $sec.Name}}{{if $si}}
{{end}}## {{$sec.Name}}{{if $sec.Description}}{{"\n\n"}}{{$sec.Description}}{{end}}{{"\n\n"}}
{{- end -}}
{{- /* Functions within section, with blank-line separators where needed */ -}}
{{- range $fi, $f := $sec.Functions}}{{if or $fi (and (not $sec.Name) $si)}}
{{end}}{{template "funcBlock" $f}}{{end}}
{{- end}}
