{
  "name": "mylib",
  "brief": "A showcase of every shdoc-ng annotation.",
  "description": "This library **demonstrates** all supported tags.\n\nFeatures include:\n\n* Function documentation\n* Deprecation notices\n* Grouped sections",
  "authors": [
    "Alice",
    "Bob"
  ],
  "license": "MIT",
  "version": "2.0.0",
  "sections": [
    {
      "name": "String Utilities",
      "description": "Common string operations.",
      "functions": [
        {
          "name": "greet",
          "description": "Greet someone by name.\n\nPrints a friendly **greeting** to stdout. Returns non-zero\nif no name is provided.",
          "example": "   greet \"World\"\n   greet \"$(whoami)\"",
          "options": [
            {
              "forms": [
                {
                  "name": "-u"
                },
                {
                  "name": "--uppercase"
                }
              ],
              "description": "Uppercase the name."
            },
            {
              "forms": [
                {
                  "name": "-n",
                  "value": "count",
                  "value_sep": " "
                },
                {
                  "name": "--repeat",
                  "value": "count",
                  "value_sep": "="
                }
              ],
              "description": "Repeat the greeting."
            },
            {
              "forms": [
                {
                  "name": "-r"
                },
                {
                  "name": "--reverse"
                }
              ],
              "description": "Reverse the greeting."
            }
          ],
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "The name to greet."
            },
            {
              "name": "$@",
              "type": "string",
              "description": "Additional names."
            }
          ],
          "set": [
            {
              "name": "LAST_GREETED",
              "type": "string",
              "description": "The last name that was greeted."
            }
          ],
          "env": [
            {
              "name": "HOME",
              "type": "string",
              "description": "The user's home directory."
            }
          ],
          "exitcodes": [
            {
              "code": "0",
              "description": "If successful."
            },
            {
              "code": "1",
              "description": "If no name was provided."
            }
          ],
          "stdin": [
            "A fallback name, read if $1 is empty."
          ],
          "stdout": [
            "The greeting string."
          ],
          "stderr": [
            "A warning when no name is given."
          ],
          "see": [
            {
              "kind": "ref",
              "text": "farewell()"
            },
            {
              "kind": "url",
              "href": "https://www.gnu.org/software/bash/"
            },
            {
              "kind": "path",
              "href": "./lib/helpers.sh"
            },
            {
              "kind": "link",
              "text": "Bash manual",
              "href": "https://www.gnu.org/software/bash/manual/"
            },
            {
              "kind": "text",
              "text": "See also the [bash guide](https://tldp.org/LDP/abs/html/) and https://mywiki.wooledge.org/BashFAQ."
            }
          ],
          "warnings": [
            "Do not pass empty strings."
          ]
        },
        {
          "name": "farewell",
          "description": "Say goodbye.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "The name to bid farewell."
            }
          ],
          "exitcodes": [
            {
              "code": "0",
              "description": "Always."
            }
          ],
          "see": [
            {
              "kind": "ref",
              "text": "greet()"
            }
          ]
        }
      ]
    },
    {
      "name": "Deprecated Utilities",
      "description": "Functions kept for backwards compatibility.",
      "functions": [
        {
          "name": "old_hello",
          "description": "This function is obsolete.",
          "is_deprecated": true,
          "deprecated_message": "Use greet() instead."
        },
        {
          "name": "old_noop",
          "is_deprecated": true
        },
        {
          "name": "braceless_func",
          "description": "A function whose opening brace\nis on the next line.",
          "is_noargs": true
        },
        {
          "name": "subshell_func",
          "description": "A subshell function using parens\ninstead of braces.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "A command to run in a subshell."
            }
          ]
        }
      ]
    },
    {
      "name": "LSP & Highlight Testing",
      "description": "Cases to exercise syntax highlighting, diagnostics, and LSP features.",
      "functions": [
        {
          "name": "multi_arg_func",
          "description": "Multiple arguments with different types.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "The input file path."
            },
            {
              "name": "$2",
              "type": "int",
              "description": "Number of lines to read."
            },
            {
              "name": "$3",
              "type": "bool",
              "description": "Whether to trim whitespace."
            },
            {
              "name": "$@",
              "type": "string",
              "description": "Remaining arguments forwarded to helper."
            }
          ]
        },
        {
          "name": "option_variety",
          "description": "Various option forms.",
          "options": [
            {
              "forms": [
                {
                  "name": "-v"
                }
              ],
              "description": "Enable verbose mode."
            },
            {
              "forms": [
                {
                  "name": "--dry-run"
                }
              ],
              "description": "Do not actually execute."
            },
            {
              "forms": [
                {
                  "name": "-o",
                  "value": "path",
                  "value_sep": " "
                },
                {
                  "name": "--output",
                  "value": "path",
                  "value_sep": " "
                }
              ],
              "description": "Write output to file."
            },
            {
              "forms": [
                {
                  "name": "-f"
                },
                {
                  "name": "--force"
                }
              ],
              "description": "Force overwrite."
            },
            {
              "forms": [
                {
                  "name": "--timeout",
                  "value": "seconds",
                  "value_sep": "="
                }
              ],
              "description": "Timeout in seconds."
            }
          ]
        },
        {
          "name": "env_and_set_func",
          "description": "Exercises @set and @env highlighting.",
          "is_noargs": true,
          "set": [
            {
              "name": "RESULT_CODE",
              "type": "int",
              "description": "The result code."
            },
            {
              "name": "OUTPUT_PATH",
              "type": "string",
              "description": "The generated output path."
            }
          ],
          "env": [
            {
              "name": "LANG",
              "type": "string",
              "description": "The current locale."
            },
            {
              "name": "TERM",
              "type": "string",
              "description": "The terminal type."
            }
          ]
        },
        {
          "name": "multi_exitcode",
          "description": "Multiple exit codes with prefix variants.",
          "is_noargs": true,
          "exitcodes": [
            {
              "code": "0",
              "description": "Success."
            },
            {
              "code": "1",
              "description": "General error."
            },
            {
              "code": "2",
              "description": "Misuse of shell builtins."
            },
            {
              "code": "127",
              "description": "Command not found."
            },
            {
              "code": ">0",
              "description": "Any failure."
            },
            {
              "code": "!0",
              "description": "Non-zero exit."
            }
          ]
        },
        {
          "name": "noargs_but_uses_params",
          "description": "Should warn: uses $1 despite @noargs.",
          "is_noargs": true
        },
        {
          "name": "noargs_with_awk",
          "description": "Should NOT warn: $1 is inside single quotes (awk).",
          "is_noargs": true
        },
        {
          "name": "old_parse",
          "description": "Old parser, use new_parse() instead.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "Input text."
            }
          ],
          "is_deprecated": true,
          "deprecated_message": "Replaced by new_parse()."
        },
        {
          "name": "new_parse",
          "description": "New parser.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "Input text."
            }
          ]
        },
        {
          "name": "empty_tags_func",
          "env": [
            {
              "name": "FOO",
              "type": "",
              "description": ""
            }
          ],
          "stdin": [
            ""
          ],
          "stdout": [
            ""
          ],
          "stderr": [
            ""
          ],
          "see": [
            {
              "kind": "ref"
            }
          ]
        },
        {
          "name": "see_references",
          "description": "A function that references others via @see.",
          "is_noargs": true,
          "see": [
            {
              "kind": "ref",
              "text": "greet()"
            },
            {
              "kind": "ref",
              "text": "farewell()"
            },
            {
              "kind": "ref",
              "text": "old_parse()"
            }
          ]
        },
        {
          "name": "single_line_doc",
          "description": "This is a single-line doc block (no fold arrow expected)."
        },
        {
          "name": "multi_line_doc",
          "description": "This is a multi-line doc block.\n\nIt spans several comment lines, so it should\nbe foldable in the editor.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "Something."
            }
          ],
          "exitcodes": [
            {
              "code": "0",
              "description": "Always."
            }
          ]
        },
        {
          "name": "keyword_no_parens",
          "description": "Uses the 'function' keyword without parens.",
          "is_noargs": true
        },
        {
          "name": "keyword_with_parens",
          "description": "Uses the 'function' keyword with parens.",
          "args": [
            {
              "name": "$1",
              "type": "string",
              "description": "A value."
            }
          ]
        },
        {
          "name": "multiline_io",
          "description": "Demonstrates multi-line IO docs.",
          "is_noargs": true,
          "stdin": [
            "Lines of text, one per line.\nEach line should be tab-separated.\nEmpty lines are skipped."
          ],
          "stdout": [
            "Processed output.\nFirst line is a header.\nSubsequent lines are data rows."
          ],
          "stderr": [
            "Progress messages.\nPrefixed with the current timestamp."
          ]
        }
      ]
    }
  ]
}
