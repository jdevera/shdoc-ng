{
  "scopeName": "annotation.shdoc-ng",
  "injectionSelector": "L:source.shell",
  "patterns": [
    {
      "comment": "@arg $name type Description",
      "name": "comment.line.documentation.shdoc-ng",
      "match": "^\\s*#\\s*(@)(arg)\\s+(\\$(?:[0-9]+|@))\\s+(\\S+).*$",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.shdoc-ng" },
        "2": { "name": "keyword.other.shdoc-ng" },
        "3": { "name": "variable.parameter.shdoc-ng" },
        "4": { "name": "support.type.shdoc-ng" }
      }
    },
    {
      "comment": "@set/@env VARNAME [type [Description]]",
      "name": "comment.line.documentation.shdoc-ng",
      "match": "^\\s*#\\s*(@)(set|env)\\s+(\\S+)(?:\\s+(\\S+))?.*$",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.shdoc-ng" },
        "2": { "name": "keyword.other.shdoc-ng" },
        "3": { "name": "variable.other.shdoc-ng" },
        "4": { "name": "support.type.shdoc-ng" }
      }
    },
    {
      "comment": "@exitcode/@exit N Description",
      "name": "comment.line.documentation.shdoc-ng",
      "match": "^\\s*#\\s*(@)(exitcode|exit)\\s+([0-9]+).*$",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.shdoc-ng" },
        "2": { "name": "keyword.other.shdoc-ng" },
        "3": { "name": "constant.numeric.shdoc-ng" }
      }
    },
    {
      "comment": "@option/@opt with flags and placeholders",
      "name": "comment.line.documentation.shdoc-ng",
      "begin": "^\\s*#\\s*(@)(option|opt)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.shdoc-ng" },
        "2": { "name": "keyword.other.shdoc-ng" }
      },
      "end": "$",
      "patterns": [
        {
          "match": "(?<=\\s|\\||/)-{1,2}[a-zA-Z][a-zA-Z0-9_-]*",
          "name": "entity.name.function.shdoc-ng"
        },
        {
          "match": "<[^>]+>",
          "name": "variable.other.shdoc-ng"
        }
      ]
    },
    {
      "comment": "All other @tags (no special sub-highlighting needed)",
      "name": "comment.line.documentation.shdoc-ng",
      "match": "^\\s*#\\s*(@)(description|desc|arg|example|exitcode|exit|see|warning|warn|deprecated|noargs|internal|name|brief|file|author|license|version|section|set|env|stdin|stdout|stderr|option|opt)\\b.*$",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.shdoc-ng" },
        "2": { "name": "keyword.other.shdoc-ng" }
      }
    }
  ]
}
